<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Production Planning" Height="450" Width="800">
  <Grid>
    <DockPanel LastChildFill="True">
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Background="#EEE" Height="40">
        <Button Name="BtnHome" Width="100" Margin="6">Home</Button>
        <Button Name="BtnData" Width="120" Margin="6">Data Sources</Button>
        <Button Name="BtnExit" Width="80" Margin="6">Exit</Button>
      </StackPanel>
      <Frame Name="MainFrame" NavigationUIVisibility="Hidden" />
    </DockPanel>
  </Grid>
</Window>
